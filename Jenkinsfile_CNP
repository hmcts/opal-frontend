    env.DEV_DEFAULT_APP_MODE = 'legacy'
    env.DEV_OPAL_LEGACY_GATEWAY_URL = 'https://opal.clouddev.online/opal'
    env.OPAL_LOG_LEVEL = 'DEBUG'
} else if (legacyEnabled && !isPR) {
