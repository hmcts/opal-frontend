#!groovy
/* groovylint-disable CompileStatic */
import java.time.DayOfWeek
import java.time.ZonedDateTime

properties([
    // H allow predefined but random minute see https://en.wikipedia.org/wiki/Cron#Non-standard_characters
    pipelineTriggers([cron('H 07 * * 1-5')]),
    copyArtifactPermission('*'),
    parameters([
    booleanParam(name: 'Component', defaultValue: true, description: 'Run component tests'),
    booleanParam(name: 'Smoke', defaultValue: true, description: 'Run smoke tests'),
    booleanParam(name: 'Functional', defaultValue: true, description: 'Run functional tests'),
    booleanParam(name: 'Legacy', defaultValue: false, description: 'Run legacy tests'),
    booleanParam(name: 'RunEdge', defaultValue: false, description: 'Run Edge tests'),
    booleanParam(name: 'RunFirefox', defaultValue: false, description: 'Run Firefox tests'),
    booleanParam(name: 'ZephyrExecution', defaultValue: false, description: 'Create Zephyr Execution'),
    choice(
      name: 'LEGACY_URL',
      choices: ['PRE-PROD', 'DEV'],
      description: 'Determines the URL to use for legacy tests.'
    ),
  ])
])

@Library('Infrastructure')

String type = 'angular'
String product = 'opal'
String component = 'frontend'
String failureResult = 'FAILURE'
String secretKey = 'opal-$'.concat('{env}')

Map<String, List<Map<String, Object>>> secrets = [
  (secretKey): [
    secret('OpalTestUserEmail', 'OPAL_TEST_USER_EMAIL'),
    secret('OpalTestUserPassword', 'OPAL_TEST_USER_PASSWORD'),
    secret('jiraAuthToken', 'JIRA_AUTH_TOKEN'),
  ],
]

static Map<String, Object> secret(String secretName, String envVar) {
  return [$class     : 'AzureKeyVaultSecret',
    secretType : 'Secret',
    name       : secretName,
    version    : '',
    envVariable: envVar
  ]
}

uk.gov.hmcts.contino.YarnBuilder yarnBuilder =
  new uk.gov.hmcts.contino.YarnBuilder(this)

String defaultBrowser() {
  return 'edge'
}

void archiveFunctionalProdArtifacts() {
  archiveArtifact('functional-output/prod/**')
}

void archiveArtifact(String path) {
  archiveArtifacts artifacts: path, allowEmptyArchive: true
}

void publishHtmlReport(String dir, String files, String name) {
  publishHTML target: [
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : dir,
    reportFiles          : files,
    reportName           : name
  ]
}

void runNightlyStage(
  boolean enabled,
  String stageName,
  String failureResultValue,
  String failureMessage,
  Closure body
) {
  if (!enabled) {
    return
  }

  stage(stageName) {
    catchError(
      buildResult: failureResultValue,
      stageResult: failureResultValue,
      message: failureMessage
    ) {
      body.call()
    }
  }
}

void archiveNightlyWeightArtifacts() {
  script {
    String sourceJobName = env.JOB_NAME
    String pipelineDir = 'cypress/parallel/weights/pipeline'
    String weightsDir = 'cypress/parallel/weights'
    String smokeWeights = 'smoke-parallel-weights.json'
    String functionalWeights = 'functional-parallel-weights.json'

    sh "mkdir -p ${pipelineDir}"
    sh "cp -r ${weightsDir}/${smokeWeights} ${pipelineDir}/"
    sh "cp -r ${weightsDir}/${functionalWeights} ${pipelineDir}/"

    sh "echo 'Archiving weight files in ${sourceJobName}'"
    archiveArtifact("${pipelineDir}/${smokeWeights}")
    archiveArtifact("${pipelineDir}/${functionalWeights}")
    archiveArtifact('cypress/reports/smokeXmlReport.html')
    archiveArtifact('cypress/reports/functionalXmlReport.html')
  }
}

void runComponentStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  boolean shouldRunWithZephyr,
  String browserToRun
) {
  runNightlyStage(enabled, 'Component Tests', failureResultValue, 'Component tests failed') {
    try {
      builder.yarn(shouldRunWithZephyr ? 'zephyr:test:opalComponent' : 'test:opalComponent')
    } finally {
      archiveFunctionalProdArtifacts()
      archiveArtifact("functional-output/screenshots/${browserToRun}/component/**")
      publishHtmlReport(
        "functional-output/component-html/${browserToRun}/",
        'component-report.html',
        "Component Test Report (${browserToRun})"
      )
    }
  }
}

void runSmokeStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  String browserToRun
) {
  runNightlyStage(enabled, 'Smoke Tests', failureResultValue, 'Smoke tests failed') {
    try {
      builder.yarn('test:smoke')
    } finally {
      archiveArtifact('smoke-output/prod/**')
      archiveArtifact("smoke-output/screenshots/${browserToRun}/**")
      publishHtmlReport(
        "smoke-output/prod/${browserToRun}/cucumber/",
        'smoke-report.html',
        "${browserToRun.capitalize()} Smoke Test Report"
      )
    }
  }
}

void runFunctionalStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  boolean shouldRunWithZephyr,
  String browserToRun
) {
  runNightlyStage(enabled, 'Functional Tests', failureResultValue, 'Functional tests failed') {
    try {
      builder.yarn(shouldRunWithZephyr ? 'zephyr:test:functional' : 'test:functional')
    } finally {
      archiveFunctionalProdArtifacts()
      archiveArtifact("functional-output/screenshots/${browserToRun}/**")
      publishHtmlReport(
        "functional-output/prod/${browserToRun}/cucumber/",
        "${browserToRun}-report.html",
        "${browserToRun.capitalize()} Functional Test Report"
      )
      archiveNightlyWeightArtifacts()
    }
  }
}

void runLegacyStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  String browserToRun
) {
  runNightlyStage(enabled, 'Legacy Tests', failureResultValue, 'Legacy tests failed') {
    try {
      builder.yarn(
        'yarn test:functionalLegacy ; ' +
        'yarn test:functionalLegacy:combine:reports ; ' +
        'yarn test:functionalLegacy:cucumber:combineParallelReport'
      )
    } finally {
      archiveArtifact("functional-output/prod/${browserToRun}/legacy/**")
      archiveArtifact("functional-output/screenshots/${browserToRun}/legacy/**")
      publishHtmlReport(
        "functional-output/prod/${browserToRun}/legacy/cucumber/",
        'legacy-report.html',
        "${browserToRun.capitalize()} Legacy Functional Test Report"
      )
    }
  }
}

void runBrowserStage(
  boolean enabled,
  String failureResultValue,
  String failureMessage,
  uk.gov.hmcts.contino.YarnBuilder builder,
  Map<String, String> stageConfig
) {
  runNightlyStage(enabled, stageConfig.stageName, failureResultValue, failureMessage) {
    try {
      builder.yarn(stageConfig.yarnCommand)
    } finally {
      archiveArtifact("functional-output/prod/${stageConfig.browserToRun}/**")
      archiveArtifact("functional-output/screenshots/${stageConfig.browserToRun}/**")
      publishHtmlReport(
        "functional-output/prod/${stageConfig.browserToRun}/cucumber/",
        "${stageConfig.browserToRun}-report.html",
        "${stageConfig.browserToRun.capitalize()} Functional Test Report"
      )
    }
  }
}

void performArtifactOperations() {
  sh 'mkdir -p cypress/parallel/weights/pipeline'

  sh '''
    echo "Listing all artifacts before copy artifacts:"
    ls -l1a cypress/parallel/weights/
    ls -l1a cypress/parallel/weights/pipeline/
    '''

  script {
    String projectName = 'HMCTS_Nightly/opal-frontend/master'
    try {
      copyArtifacts(
        projectName: projectName,
        selector: lastSuccessful(),
        filter: '**/cypress/parallel/weights/pipeline/*'
      )
    } catch (hudson.AbortException e) {
      echo "Error copying artifacts: ${e}"
    }

    sh '''
      echo "Listing all artifacts after copy artifacts:"
      ls -l1a cypress/parallel/weights/
      ls -l1a cypress/parallel/weights/pipeline/
      '''
  }

  try {
    sh '''
        PIPELINE_DIR='cypress/parallel/weights/pipeline'
        WEIGHTS_DIR='cypress/parallel/weights'

        if [ -f "$PIPELINE_DIR/smoke-parallel-weights.json" ]; then
            mv "$PIPELINE_DIR/smoke-parallel-weights.json" \
              "$WEIGHTS_DIR/smoke-parallel-weights.json"
            echo "Moved smoke-parallel-weights.json"
        else
            echo "smoke-parallel-weights.json not found, skipping move"
        fi
        if [ -f "$PIPELINE_DIR/functional-parallel-weights.json" ]; then
            mv "$PIPELINE_DIR/functional-parallel-weights.json" \
              "$WEIGHTS_DIR/functional-parallel-weights.json"
            echo "Moved functional-parallel-weights.json"
        else
            echo "functional-parallel-weights.json not found, skipping move"
        fi
        if [ -f "$PIPELINE_DIR/component-parallel-weights.json" ]; then
            mv "$PIPELINE_DIR/component-parallel-weights.json" \
              "$WEIGHTS_DIR/component-parallel-weights.json"
            echo "Moved component-parallel-weights.json"
        else
            echo "component-parallel-weights.json not found, skipping move"
        fi
        '''
  } catch (hudson.AbortException e) {
    echo "Artifacts not found or copy failed: ${e}"
  }

  sh '''
    echo "Listing all copied artifacts:"
    ls -l1a cypress/parallel/weights/
    ls -l1a cypress/parallel/weights/pipeline/
    '''
}
void setupTestSpecifications() {
  script {
    env.TEST_SPECS = 'cypress/e2e/functional/opal/**/*.feature'
  }
}

withNightlyPipeline(type, product, component) {
  loadVaultSecrets(secrets)
  env.TEST_URL = 'https://opal-frontend.staging.platform.hmcts.net/'
  env.BROWSER_TO_RUN = (env.BROWSER_TO_RUN ?: defaultBrowser()).trim().toLowerCase()

  before('akschartsinstall') {
    onPR {
      env.DEV_ENABLE_OPAL_FINES_SERVICE = true
      env.DEV_OPAL_FINES_SERVICE_URL = 'https://opal-frontend.staging.platform.hmcts.net'
      env.DEV_OPAL_FINES_SERVICE_IMAGE_SUFFIX = 'latest'
    }
  }
  afterSuccess('checkout') {
    performArtifactOperations()
    setupTestSpecifications()
  }

  afterAlways('DependencyCheckNightly') {
    String browserToRun = env.BROWSER_TO_RUN
    echo 'Component:' + params.Component
    echo 'Smoke:' + params.Smoke
    echo 'Functional:' + params.Functional
    echo 'Legacy:' + params.Legacy
    echo 'RunEdge:' + params.RunEdge
    echo 'RunFirefox:' + params.RunFirefox

    DayOfWeek today = ZonedDateTime.now().dayOfWeek
    boolean shouldRunWithZephyr = params.ZephyrExecution || today == DayOfWeek.FRIDAY
    if (shouldRunWithZephyr) {
      String buildDescription =
        "Nightly execution for commit ${env.GIT_COMMIT} on environment ${env.ENVIRONMENT_NAME}.\n"
      String buildUrl =
        "https://sds-build.hmcts.net/job/HMCTS_Nightly/job/opal-frontend/job/master/${env.BUILD_NUMBER}/"

      env.EXECUTION_BUILD = env.GIT_COMMIT
      env.EXECUTION_ENVIRONMENT = env.ENVIRONMENT_NAME
      env.EXECUTION_CYCLE_DESCRIPTION = buildDescription + buildUrl
      echo """\
Zephyr execution will be created with the following details:
Build: ${env.EXECUTION_BUILD}
Environment: ${env.EXECUTION_ENVIRONMENT}
Description: ${env.EXECUTION_CYCLE_DESCRIPTION}
""".stripIndent()
    }
    runComponentStage(
      params.Component,
      failureResult,
      yarnBuilder,
      shouldRunWithZephyr,
      browserToRun
    )
    runSmokeStage(params.Smoke, failureResult, yarnBuilder, browserToRun)
    runFunctionalStage(
      params.Functional,
      failureResult,
      yarnBuilder,
      shouldRunWithZephyr,
      browserToRun
    )
    runLegacyStage(params.Legacy, failureResult, yarnBuilder, browserToRun)
    runBrowserStage(
      params.RunEdge,
      failureResult,
      'Edge tests failed',
      yarnBuilder,
      [
        stageName   : 'Edge Tests',
        yarnCommand : 'test:Edge',
        browserToRun: defaultBrowser(),
      ]
    )
    runBrowserStage(
      params.RunFirefox,
      failureResult,
      'Firefox tests failed',
      yarnBuilder,
      [
        stageName   : 'Firefox Tests',
        yarnCommand : 'test:Firefox',
        browserToRun: 'firefox',
      ]
    )
  }
}
