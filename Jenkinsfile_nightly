// Build an Azure KeyVault secret entry.
static Map<String, Object> secret(String secretName, String envVar) {
  return [$class     : 'AzureKeyVaultSecret',
    secretType : 'Secret',
    name       : secretName,
    version    : '',
    envVariable: envVar
  ]
}

