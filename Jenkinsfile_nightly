// Check whether the requested browser binary is available on the Jenkins agent.
boolean isBrowserInstalled(String browser) {
  return sh(
    returnStatus: true,
    script: """
      case '${browser}' in
        ${browserEdge})
          command -v microsoft-edge >/dev/null 2>&1 ||
          command -v microsoft-edge-stable >/dev/null 2>&1 ||
          command -v msedge >/dev/null 2>&1 ||
          [ -x '/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge' ]
          ;;
        ${browserChrome})
          command -v google-chrome >/dev/null 2>&1 ||
          command -v google-chrome-stable >/dev/null 2>&1 ||
          command -v chrome >/dev/null 2>&1 ||
          [ -x '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' ]
          ;;
        ${browserFirefox})
          command -v firefox >/dev/null 2>&1 ||
          command -v firefox-bin >/dev/null 2>&1 ||
          [ -x '/Applications/Firefox.app/Contents/MacOS/firefox' ]
          ;;
        *)
          exit 1
          ;;
      esac
    """
  ) == zeroIndex
}

// Emit a prominent banner when the pipeline falls back to a different browser.
void echoBrowserFallbackBanner(String missingBrowser, String fallbackBrowser) {
  echo """\
========================================================================
${missingBrowser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
SWITCHING TO ${fallbackBrowser.toUpperCase()} FOR THIS PIPELINE RUN
========================================================================
""".stripIndent()
}

// Emit a prominent banner when a browser is unavailable on the current agent.
void echoBrowserMissingBanner(String browser) {
  echo """\
========================================================================
${browser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
${browser.toUpperCase()}-SPECIFIC RUNS WILL NOT BE AVAILABLE ON THIS AGENT
========================================================================
""".stripIndent()
}

// Choose the browser for this run, falling back from Edge to Chrome when needed.
String resolvePipelineBrowser(String requestedBrowser) {
  String normalizedBrowser = (requestedBrowser ?: browserEdge).trim().toLowerCase()

  if (normalizedBrowser == browserEdge && !isBrowserInstalled(browserEdge)) {
    if (isBrowserInstalled(browserChrome)) {
      echoBrowserFallbackBanner(browserEdge, browserChrome)
      return browserChrome
    }

    error '''\
========================================================================
EDGE IS NOT INSTALLED ON THIS JENKINS AGENT
CHROME IS ALSO NOT AVAILABLE AS A FALLBACK
INSTALL A SUPPORTED BROWSER OR SET BROWSER_TO_RUN EXPLICITLY
========================================================================
'''.stripIndent()
  }

  return normalizedBrowser
}

// Require an explicitly requested browser to be present before running its stage.
String requireInstalledBrowser(String browser) {
  if (!isBrowserInstalled(browser)) {
    echoBrowserMissingBanner(browser)
    error """\
========================================================================
${browser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
INSTALL ${browser.toUpperCase()} OR DISABLE THE ${browser.toUpperCase()} RUN
========================================================================
""".stripIndent()
  }

  return browser
}

// Check whether any files in the workspace match the provided glob.
boolean hasMatchingFiles(String glob) {
  return findFiles(glob: glob).length > zeroIndex
}

// Archive pipeline artifacts only when the expected files are present.
void archiveArtifact(String path) {
  if (!hasMatchingFiles(path)) {
    echo "Skipping artifact archive for '${path}' because no matching files were created."
    return
  }

  archiveArtifacts artifacts: path, allowEmptyArchive: true
}

// Archive Zephyr JSON reports for a test output directory.
void archiveZephyrReports(String outputDir) {
  archiveArtifact("${outputDir}/zephyr/cucumber-report.json")
  archiveArtifact("${outputDir}/zephyr/cypress-report-1.json")
}

// Copy generated Zephyr JSON reports into a stage-specific artifact directory.
void copyZephyrReports(String sourceOutputDir, String targetOutputDir) {
  sh """
    SOURCE_ZEPHYR_DIR='${sourceOutputDir}/zephyr'
    TARGET_ZEPHYR_DIR='${targetOutputDir}/zephyr'
    mkdir -p "\$TARGET_ZEPHYR_DIR"

    if [ -f "\$SOURCE_ZEPHYR_DIR/cucumber-report.json" ]; then
      cp "\$SOURCE_ZEPHYR_DIR/cucumber-report.json" "\$TARGET_ZEPHYR_DIR/cucumber-report.json"
    fi
    if [ -f "\$SOURCE_ZEPHYR_DIR/cypress-report-1.json" ]; then
      cp "\$SOURCE_ZEPHYR_DIR/cypress-report-1.json" "\$TARGET_ZEPHYR_DIR/cypress-report-1.json"
    fi
  """
}

// Publish an HTML report directory with Jenkins HTML Publisher when the report exists.
void publishHtmlReport(String dir, String files, String name) {
  String normalizedDir = dir.endsWith('/') ? dir[zeroIndex..-2] : dir
  String reportGlob = "${normalizedDir}/${files}"

  if (!fileExists(normalizedDir)) {
    echo "Skipping HTML report '${name}' because directory '${normalizedDir}' was not created."
    return
  }

  if (!hasMatchingFiles(reportGlob)) {
    echo "Skipping HTML report '${name}' because report files matching '${reportGlob}' were not created."
    return
  }

  publishHTML target: [
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : normalizedDir,
    reportFiles          : files,
    reportName           : name
  ]
}

// Run a nightly stage with standard error handling and failure reporting.
void runNightlyStage(
  boolean enabled,
  String stageName,
  String failureResultValue,
  String failureMessage,
  Closure body
) {
  if (!enabled) {
    return
  }

  stage(stageName) {
    catchError(
      buildResult: failureResultValue,
      stageResult: failureResultValue,
      message: failureMessage
    ) {
      body.call()
    }
  }
}

// Resolve the LaunchDarkly variation index for the requested app-mode variation.
int resolveLaunchDarklyVariationIndex(String variationName) {
  int variationIndex = launchDarklyVariationOrder.indexOf(variationName)
  if (variationIndex < zeroIndex) {
    error "Unsupported LaunchDarkly variation name '${variationName}'. Expected one of ${launchDarklyVariationOrder}."
  }
  return variationIndex
}

// Patch the LaunchDarkly app-mode flag for nightly legacy-mode demo checks.
void patchLaunchDarklyFlagState(boolean enabled, String variationName, String actionMessage) {
  int variationIndex = resolveLaunchDarklyVariationIndex(variationName)
  String patchPayload =
    '{"patch":[' +
    "{\"op\":\"replace\",\"path\":\"/environments/${launchDarklyEnvironmentKey}/on\",\"value\":${enabled}}," +
    "{\"op\":\"replace\",\"path\":\"/environments/${launchDarklyEnvironmentKey}/fallthrough/variation\"," +
    "\"value\":${variationIndex}}" +
    ']}'

  sh """
    echo '${actionMessage}'
    set +x
    if [ -z "\$LD_API_TOKEN" ]; then
      echo 'Missing required LaunchDarkly secret env var: LD_API_TOKEN'
      exit 1
    fi
    LD_URL="https://app.launchdarkly.com/api/v2/flags/${product}/${launchDarklyFlagKey}"
    LD_HTTP_CODE=\$(curl -s -o ld_patch_response.json -w '%{http_code}' -X PATCH \\
      -H "Authorization: \$LD_API_TOKEN" \\
      -H "LD-API-Version: ${launchDarklyApiVersion}" \\
      -H "Content-Type: application/json" \\
      -d '${patchPayload}' \\
      "\$LD_URL")
    LD_CURL_EXIT=\$?
    echo "LaunchDarkly PATCH HTTP status: \$LD_HTTP_CODE"
    if [ -s ld_patch_response.json ]; then
      echo 'LaunchDarkly PATCH response body:'
      cat ld_patch_response.json
    fi
    if [ "\$LD_CURL_EXIT" -ne 0 ]; then
      echo 'LaunchDarkly PATCH request failed to execute.'
      exit 1
    fi
    if ! echo "\$LD_HTTP_CODE" | grep -Eq '^[0-9]{3}\$'; then
      echo 'LaunchDarkly PATCH returned an invalid status code.'
      exit 1
    fi
    if [ "\$LD_HTTP_CODE" -lt 200 ] || [ "\$LD_HTTP_CODE" -ge 300 ]; then
      echo 'LaunchDarkly PATCH failed with non-2xx status.'
      exit 1
    fi
  """
}

// Resolve the legacy gateway URL used by nightly demo legacy checks.
String resolveLegacyDemoGatewayUrl() {
  boolean useDevLegacyGateway = params.LEGACY_URL == legacyUrlDevChoice
  return useDevLegacyGateway ? legacyGatewayUrlDev : legacyGatewayUrlPreProd
}

// Probe the nightly legacy health endpoint used before running demo legacy checks.
String getLegacyHealthCheckStatus() {
  String legacyHealthEndpoint = "${resolveLegacyDemoGatewayUrl()}?actionType=getGmasTest"
  return sh(
    script:
      "curl -s -o /dev/null -w '%{http_code}' " +
      '-X POST ' +
      "-H 'Content-Type: application/json' " +
      "--data '${legacyHealthCheckPayload}' " +
      "'${legacyHealthEndpoint}' || echo '000'",
    returnStdout: true
  ).trim()
}

// Run the legacy gateway health check only when the selected gateway supports it.
boolean shouldRunLegacyHealthCheck() {
  return params.LEGACY_URL == legacyUrlPreProdChoice
}

// Patch LaunchDarkly app mode only when running demo legacy checks against pre-prod.
boolean shouldPatchLaunchDarklyForDemoLegacyStage() {
  return params.LEGACY_URL == legacyUrlPreProdChoice
}

// Wait until the legacy health endpoint responds successfully after toggling app mode.
void waitForLegacyHealthCheck() {
  if (!shouldRunLegacyHealthCheck()) {
    echo "Skipping legacy health check because LEGACY_URL=${params.LEGACY_URL} uses the DEV stub."
    return
  }

  timeout(time: uatHealthCheckTimeoutMinutes, unit: 'MINUTES') {
    script {
      boolean healthy = false
      int maxAttempts = Math.max(
        1,
        (int) Math.ceil((uatHealthCheckTimeoutMinutes * 60.0d) / uatHealthCheckIntervalSeconds)
      )

      for (int attemptIndex = zeroIndex; attemptIndex < maxAttempts; attemptIndex++) {
        String statusCode = legacyHealthCheckStatus
        if (statusCode.startsWith('2')) {
          echo "Health check OK (HTTP ${statusCode})"
          healthy = true
          break
        }

        int attemptNumber = attemptIndex + 1
        echo "Health check returned ${statusCode}, waiting ${uatHealthCheckIntervalSeconds}s " +
          "(attempt ${attemptNumber}/${maxAttempts})..."
        sleep uatHealthCheckIntervalSeconds
      }

      if (!healthy) {
        error 'Health check did not succeed in time'
      }
    }
  }
}

// Archive updated parallel weight files for reuse by later nightly runs.
void archiveNightlyWeightArtifacts() {
  script {
    String sourceJobName = env.JOB_NAME
    String pipelineDir = 'cypress/parallel/weights/pipeline'
    String weightsDir = 'cypress/parallel/weights'
    String smokeWeights = 'smoke-parallel-weights.json'
    String functionalWeights = 'functional-parallel-weights.json'

    sh "mkdir -p ${pipelineDir}"
    sh "cp -r ${weightsDir}/${smokeWeights} ${pipelineDir}/"
    sh "cp -r ${weightsDir}/${functionalWeights} ${pipelineDir}/"

    sh "echo 'Archiving weight files in ${sourceJobName}'"
    archiveArtifact("${pipelineDir}/${smokeWeights}")
    archiveArtifact("${pipelineDir}/${functionalWeights}")
    archiveArtifact('cypress/reports/smokeXmlReport.html')
    archiveArtifact('cypress/reports/functionalXmlReport.html')
  }
}

// Copy generated legacy demo report artifacts into a dedicated directory for publishing.
void prepareLegacyDemoArtifacts(String browserToRun, String outputDirName, String reportFilePrefix) {
  sh """
    OUTPUT_DIR='${functionalOutputRoot}/prod/${browserToRun}/${outputDirName}'
    OUTPUT_CUCUMBER_DIR="\$OUTPUT_DIR/cucumber"
    SOURCE_CUCUMBER_DIR='${functionalOutputRoot}/prod/${browserToRun}/cucumber'
    SOURCE_JUNIT_PATH='${functionalOutputRoot}/prod/${browserToRun}/${browserToRun}-test-result.xml'
    mkdir -p "\$OUTPUT_CUCUMBER_DIR"

    if [ -f "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.html" ]; then
      cp "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.html" "\$OUTPUT_CUCUMBER_DIR/${reportFilePrefix}-report.html"
    fi
    if [ -f "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.ndjson" ]; then
      cp "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.ndjson" "\$OUTPUT_CUCUMBER_DIR/${reportFilePrefix}-report.ndjson"
    fi
    if [ -f "\$SOURCE_JUNIT_PATH" ]; then
      cp "\$SOURCE_JUNIT_PATH" "\$OUTPUT_DIR/${reportFilePrefix}-test-result.xml"
    fi
  """
  copyZephyrReports(functionalOutputRoot, "${functionalOutputRoot}/prod/${browserToRun}/${outputDirName}")
}

// Run a demo environment legacy-mode stage with dedicated LaunchDarkly handling and reporting.
void runDemoLegacyStage(Map<String, Object> stageConfig, Closure runCommand) {
  boolean enabled = (stageConfig.enabled ?: false) as boolean
  String stageName = stageConfig.stageName as String
  String failureResultValue = stageConfig.failureResultValue as String
  String failureMessage = stageConfig.failureMessage as String
  String startMessage = stageConfig.startMessage as String
  String outputDirName = stageConfig.outputDirName as String
  String reportName = stageConfig.reportName as String
  String browserToRun = stageConfig.browserToRun as String
  boolean archiveAccountEvidence = (stageConfig.archiveAccountEvidence ?: false) as boolean
  List<String> extraEnv = (stageConfig.extraEnv ?: []) as List<String>
  String reportFilePrefix = outputDirName

  runNightlyStage(enabled, stageName, failureResultValue, failureMessage) {
    boolean launchDarklyFlagPatched = false
    List<String> stageEnv = [
      "TEST_URL=${nightlyTestUrlDemo}",
      'DEFAULT_APP_MODE=legacy',
      'LEGACY_ENABLED=true',
      "BROWSER_TO_RUN=${browserToRun}",
    ] + extraEnv

    try {
      echo startMessage
      if (shouldPatchLaunchDarklyForDemoLegacyStage()) {
        patchLaunchDarklyFlagState(
          true,
          launchDarklyLegacyVariationName,
          "Setting LaunchDarkly flag to legacy for demo (${stageName})..."
        )
        launchDarklyFlagPatched = true
      } else {
        echo "Skipping LaunchDarkly app-mode patch because LEGACY_URL=${params.LEGACY_URL}."
      }
      waitForLegacyHealthCheck()
      sh 'echo "Waiting 30s for system warmup..." ; sleep 30'

      withEnv(stageEnv) {
        runCommand.call()
      }
    } finally {
      prepareLegacyDemoArtifacts(browserToRun, outputDirName, reportFilePrefix)
      archiveArtifact(functionalProdArtifactsPath)
      if (archiveAccountEvidence) {
        archiveArtifact("${functionalOutputRoot}/account_evidence/created-accounts.json")
        archiveArtifact("${functionalOutputRoot}/account_evidence/**")
      }
      archiveArtifact("${functionalOutputRoot}/screenshots/${browserToRun}/**")
      archiveArtifact("${functionalOutputRoot}/prod/${browserToRun}/${outputDirName}/**")
      publishHtmlReport(
        "${functionalOutputRoot}/prod/${browserToRun}/${outputDirName}/cucumber/",
        "${reportFilePrefix}-report.html",
        reportName
      )
      if (launchDarklyFlagPatched) {
        patchLaunchDarklyFlagState(
          true,
          launchDarklyOpalVariationName,
          "Restoring LaunchDarkly flag to opal for demo (${stageName})..."
        )
      }
    }
  }
}

// Run component tests and publish browser-specific reports and screenshots.
void runComponentStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  boolean shouldRunWithZephyr,
  String browserToRun
) {
  runNightlyStage(enabled, 'Component Tests', failureResultValue, 'Component tests failed') {
    String componentCommand = shouldRunWithZephyr ? 'zephyr:test:component' : 'test:component'

    try {
      builder.yarn(componentCommand)
    } finally {
      copyZephyrReports(functionalOutputRoot, "${functionalOutputRoot}/component/${browserToRun}")
      archiveArtifact("${functionalOutputRoot}/component/${browserToRun}/**")
      archiveZephyrReports("${functionalOutputRoot}/component/${browserToRun}")
      publishHtmlReport(
        "${functionalOutputRoot}/component/${browserToRun}/html/",
        'component-report.html',
        "Component Test Report (${browserToRun})"
      )
    }
  }
}

