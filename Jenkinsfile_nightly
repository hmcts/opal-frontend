/**
 * Sets environment variables required for UAT-Technical execution.
 */
void setupUatTechnicalEnvironment() {
    env.TEST_CMD = 'yarn test:functionalOpalParallel'
    env.HEALTH_ENDPOINT =
        'https://opal-frontend.staging.platform.hmcts.net/opal?actionType=getGmasTest'
    env.LD_PROJECT = product
    env.LD_ENV = launchDarklyEnvironmentKey
    env.LD_FLAG = 'app-mode'
    configureUatTechnicalTags()
}

/**
 * Sets UAT-Technical tag filters and excludes skipped scenarios.
 */
void configureUatTechnicalTags() {
    env.TAGS = "(${uatTechnicalTagExpression}) and ${skipTagExpression}"
    env.CYPRESS_TAGS = env.TAGS
    echo "Running UAT-Technical scenarios with TAGS=${env.TAGS}"
}

/**
 * Resolves LaunchDarkly variation index from configured variation name order.
 *
 * @param variationName Variation name as defined in LaunchDarkly (for example, opal or legacy).
 * @return Zero-based variation index.
 */
int resolveLaunchDarklyVariationIndex(String variationName) {
    int variationIndex = launchDarklyVariationOrder.indexOf(variationName)
    if (variationIndex < healthCheckFirstAttemptIndex) {
        error "Unsupported LaunchDarkly variation name '${variationName}'. " +
            "Expected one of ${launchDarklyVariationOrder}."
    }
    return variationIndex
}

/**
 * Patches LaunchDarkly flag state and variation for the configured environment.
 *
 * @param enabled Whether the flag should be enabled.
 * @param variationName Variation name to serve as fallthrough.
 * @param actionMessage Log message describing the patch action.
 */
void patchLaunchDarklyFlagState(boolean enabled, String variationName, String actionMessage) {
    int variationIndex = resolveLaunchDarklyVariationIndex(variationName)
    String patchPayload =
        '{"patch":[' +
        "{\"op\":\"replace\",\"path\":\"/environments/${env.LD_ENV}/on\",\"value\":${enabled}}," +
        "{\"op\":\"replace\",\"path\":\"/environments/${env.LD_ENV}/fallthrough/variation\"," +
        "\"value\":${variationIndex}}" +
        ']}'
    sh """
    echo '${actionMessage}'
    set +x
    if [ -z "${launchDarklyApiTokenEnvVarRef}" ]; then
      echo "Missing required LaunchDarkly secret env var: ${launchDarklyApiTokenEnvVar}"
      exit 1
    fi
    LD_URL="https://app.launchdarkly.com/api/v2/flags/${env.LD_PROJECT}/${env.LD_FLAG}"
    LD_HTTP_CODE=\$(curl -s -o ld_patch_response.json -w '%{http_code}' -X PATCH \\
      -H "Authorization: ${launchDarklyApiTokenEnvVarRef}" \\
      -H "LD-API-Version: ${launchDarklyApiVersion}" \\
      -H "Content-Type: application/json" \\
      -d '${patchPayload}' \\
      "\$LD_URL")
    LD_CURL_EXIT=\$?
    echo "LaunchDarkly PATCH HTTP status: \$LD_HTTP_CODE"
    if [ -s ld_patch_response.json ]; then
      echo 'LaunchDarkly PATCH response body:'
      cat ld_patch_response.json
    fi
    if [ "\$LD_CURL_EXIT" -ne 0 ]; then
      echo 'LaunchDarkly PATCH request failed to execute.'
      exit 1
    fi
    if ! echo "\$LD_HTTP_CODE" | grep -Eq '^[0-9]{3}\$'; then
      echo 'LaunchDarkly PATCH returned an invalid status code.'
      exit 1
    fi
    if [ "\$LD_HTTP_CODE" -lt 200 ] || [ "\$LD_HTTP_CODE" -ge 300 ]; then
      echo 'LaunchDarkly PATCH failed with non-2xx status.'
      exit 1
    fi
    """
}

/**
 * Sets LaunchDarkly app-mode variation to legacy for UAT-Technical.
 */
void setLaunchDarklyFlagToLegacy() {
    patchLaunchDarklyFlagState(
        true,
        launchDarklyLegacyVariationName,
        'Setting LaunchDarkly flag to legacy for staging...'
    )
}

/**
 * Performs a single health endpoint probe and returns the HTTP status code.
 *
 * @return HTTP status code string (for example, 200 or 503).
 */
String getHealthCheckStatus() {
    return sh(
        script: "curl -s -o /dev/null -w '%{http_code}' '${env.HEALTH_ENDPOINT}' || echo '000'",
        returnStdout: true
    ).trim()
}

/**
 * Polls the health endpoint until success or timeout.
 */
void waitForUatHealthCheck() {
    timeout(time: uatHealthCheckTimeoutMinutes, unit: 'MINUTES') {
        script {
            boolean healthy = false
            int maxAttempts = Math.max(
                1,
                (int) Math.ceil(
                    (uatHealthCheckTimeoutMinutes * 60.0d) / uatHealthCheckIntervalSeconds
                )
            )
            for (int i = healthCheckFirstAttemptIndex; i < maxAttempts; i++) {
                String statusCode = healthCheckStatus
                if (statusCode.startsWith('2')) {
                    echo "Health check OK (HTTP ${statusCode})"
                    healthy = true
                    break
                }
                int attemptNumber = i + 1
                echo "Health check returned ${statusCode}, waiting " +
                    "${uatHealthCheckIntervalSeconds}s (attempt ${attemptNumber}/${maxAttempts})..."
                sleep uatHealthCheckIntervalSeconds
            }
            if (!healthy) {
                error 'Health check did not succeed in time'
            }
        }
    }
}

/**
 * Runs UAT-Technical tagged tests in legacy mode.
 */
void runUatTechnicalTaggedTests() {
    sh """
    echo 'Running UAT-Technical tests (legacy mode)...'
    export TAGS='${env.TAGS}'
    export CYPRESS_TAGS='${env.CYPRESS_TAGS}'
    export TEST_MODE='LEGACY'
    ${env.TEST_CMD} || true
  """
}

/**
 * Archives UAT-Technical artifacts and JUnit XML results.
 */
void archiveUatTechnicalArtifacts() {
    publishReport(
        functionalOutputDir,
        functionalReportFile,
        uatTechnicalFunctionalReportName
    )
    archivePath(functionalArtifactsGlob)
    archivePath(accountArtifactPath)
    archivePath(accountEvidenceArtifacts)
    archivePath('functional-output/prod/uat-technical/**')
    archivePath('functional-output/screenshots/uat-technical/**')
    archivePath('cypress/reports/uat-technicalXmlReport.html')
    junit 'functional-output/prod/uat-technical/**/*.xml'
}

/**
 * Restores LaunchDarkly app-mode variation to opal.
 */
void restoreLaunchDarklyFlag() {
    patchLaunchDarklyFlagState(
        true,
        launchDarklyOpalVariationName,
        'Restoring LaunchDarkly flag to opal for staging...'
    )
}

/**
 * Orchestrates UAT-Technical flow: setup, toggle, verify, test, restore.
 */
void runUatTechnicalTests() {
    stage('UAT-Technical') {
        catchError(
            buildResult: failureResult,
            stageResult: failureResult,
            message: 'UAT-Technical failed'
        ) {
            boolean launchDarklyFlagPatched = false
            try {
                setupUatTechnicalEnvironment()
                setLaunchDarklyFlagToLegacy()
                launchDarklyFlagPatched = true
                waitForUatHealthCheck()
                sh 'echo "Waiting 30s for system warmup..." ; sleep 30'
                runUatTechnicalTaggedTests()
                archiveUatTechnicalArtifacts()
            } finally {
                if (launchDarklyFlagPatched) {
                    restoreLaunchDarklyFlag()
                }
            }
        }
    }
}

