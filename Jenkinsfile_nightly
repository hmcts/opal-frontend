// Build the nightly secret set, including LaunchDarkly credentials for demo legacy stages.
Map<String, List<Map<String, Object>>> nightlySecrets() {
  List<Map<String, Object>> nightlySecretEntries = [
    secret('OpalTestUserEmail', 'OPAL_TEST_USER_EMAIL'),
    secret('OpalTestUserPassword', 'OPAL_TEST_USER_PASSWORD'),
    secret('jiraAuthToken', 'JIRA_AUTH_TOKEN'),
    secret('launch-darkly-api-token', 'LD_API_TOKEN'),
  ]
  return [
    (secretKey): nightlySecretEntries,
  ]
}

