// Configure shared tag-filter environment variables for nightly test runs.
void configureNightlyTags() {
  String tagExpression = (params.TAGS ?: env.TAGS ?: '').trim()
  env.TAGS = tagExpression
  env.CYPRESS_TAGS = tagExpression
  env.SKIP_SMOKE = tagExpression ? 'true' : stringFalse

  if (tagExpression) {
    echo "Running nightly with TAGS=${tagExpression}"
    echo 'Skipping smoke tests for tagged nightly run.'
  } else {
    echo 'Running nightly without tag filtering.'
  }
}

// Determine whether this nightly run includes a legacy-mode test flow.
boolean legacyModeNightlyRun() {
  return params.Legacy || params.RunUatTech
}

// Set the staging legacy gateway URL used by chart templating.
void configureStagingLegacyGatewayUrl() {
  boolean shouldUsePreProdLegacyGateway =
    legacyModeNightlyRun() && params.LEGACY_URL != legacyUrlDevChoice

  env.STG_OPAL_LEGACY_GATEWAY_URL =
    shouldUsePreProdLegacyGateway ? legacyGatewayUrlPreProd : legacyGatewayUrlDev
  echo "STG_OPAL_LEGACY_GATEWAY_URL=${env.STG_OPAL_LEGACY_GATEWAY_URL}"
}

// Check whether the requested browser binary is available on the Jenkins agent.
boolean isBrowserInstalled(String browser) {
  return sh(
    returnStatus: true,
    script: """
      case '${browser}' in
        ${browserEdge})
          command -v microsoft-edge >/dev/null 2>&1 ||
          command -v microsoft-edge-stable >/dev/null 2>&1 ||
          command -v msedge >/dev/null 2>&1 ||
          [ -x '/Applications/Microsoft Edge.app/Contents/MacOS/Microsoft Edge' ]
          ;;
        ${browserChrome})
          command -v google-chrome >/dev/null 2>&1 ||
          command -v google-chrome-stable >/dev/null 2>&1 ||
          command -v chrome >/dev/null 2>&1 ||
          [ -x '/Applications/Google Chrome.app/Contents/MacOS/Google Chrome' ]
          ;;
        ${browserFirefox})
          command -v firefox >/dev/null 2>&1 ||
          command -v firefox-bin >/dev/null 2>&1 ||
          [ -x '/Applications/Firefox.app/Contents/MacOS/firefox' ]
          ;;
        *)
          exit 1
          ;;
      esac
    """
  ) == zeroIndex
}

// Emit a prominent banner when the pipeline falls back to a different browser.
void echoBrowserFallbackBanner(String missingBrowser, String fallbackBrowser) {
  echo """\
========================================================================
${missingBrowser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
SWITCHING TO ${fallbackBrowser.toUpperCase()} FOR THIS PIPELINE RUN
========================================================================
""".stripIndent()
}

// Emit a prominent banner when a browser is unavailable on the current agent.
void echoBrowserMissingBanner(String browser) {
  echo """\
========================================================================
${browser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
${browser.toUpperCase()}-SPECIFIC RUNS WILL NOT BE AVAILABLE ON THIS AGENT
========================================================================
""".stripIndent()
}

// Choose the browser for this run, falling back from Edge to Chrome when needed.
String resolvePipelineBrowser(String requestedBrowser) {
  String normalizedBrowser = (requestedBrowser ?: browserEdge).trim().toLowerCase()

  if (normalizedBrowser == browserEdge && !isBrowserInstalled(browserEdge)) {
    if (isBrowserInstalled(browserChrome)) {
      echoBrowserFallbackBanner(browserEdge, browserChrome)
      return browserChrome
    }

    error '''\
========================================================================
EDGE IS NOT INSTALLED ON THIS JENKINS AGENT
CHROME IS ALSO NOT AVAILABLE AS A FALLBACK
INSTALL A SUPPORTED BROWSER OR SET BROWSER_TO_RUN EXPLICITLY
========================================================================
'''.stripIndent()
  }

  return normalizedBrowser
}

// Require an explicitly requested browser to be present before running its stage.
String requireInstalledBrowser(String browser) {
  if (!isBrowserInstalled(browser)) {
    echoBrowserMissingBanner(browser)
    error """\
========================================================================
${browser.toUpperCase()} IS NOT INSTALLED ON THIS JENKINS AGENT
INSTALL ${browser.toUpperCase()} OR DISABLE THE ${browser.toUpperCase()} RUN
========================================================================
""".stripIndent()
  }

  return browser
}

// Archive pipeline artifacts without failing when none are present.
void archiveArtifact(String path) {
  archiveArtifacts artifacts: path, allowEmptyArchive: true
}

// Publish an HTML report directory with Jenkins HTML Publisher.
void publishHtmlReport(String dir, String files, String name) {
  publishHTML target: [
    allowMissing         : true,
    alwaysLinkToLastBuild: true,
    keepAll              : true,
    reportDir            : dir,
    reportFiles          : files,
    reportName           : name
  ]
}

// Run a nightly stage with standard error handling and failure reporting.
void runNightlyStage(
  boolean enabled,
  String stageName,
  String failureResultValue,
  String failureMessage,
  Closure body
) {
  if (!enabled) {
    return
  }

  stage(stageName) {
    catchError(
      buildResult: failureResultValue,
      stageResult: failureResultValue,
      message: failureMessage
    ) {
      body.call()
    }
  }
}

// Resolve the LaunchDarkly variation index for the requested app-mode variation.
int resolveLaunchDarklyVariationIndex(String variationName) {
  int variationIndex = launchDarklyVariationOrder.indexOf(variationName)
  if (variationIndex < zeroIndex) {
    error "Unsupported LaunchDarkly variation name '${variationName}'. Expected one of ${launchDarklyVariationOrder}."
  }
  return variationIndex
}

// Patch the LaunchDarkly app-mode flag for the nightly staging environment.
void patchLaunchDarklyFlagState(boolean enabled, String variationName, String actionMessage) {
  int variationIndex = resolveLaunchDarklyVariationIndex(variationName)
  String patchPayload =
    '{"patch":[' +
    "{\"op\":\"replace\",\"path\":\"/environments/${launchDarklyEnvironmentKey}/on\",\"value\":${enabled}}," +
    "{\"op\":\"replace\",\"path\":\"/environments/${launchDarklyEnvironmentKey}/fallthrough/variation\"," +
    "\"value\":${variationIndex}}" +
    ']}'

  sh """
    echo '${actionMessage}'
    set +x
    if [ -z "\$LD_API_TOKEN" ]; then
      echo 'Missing required LaunchDarkly secret env var: LD_API_TOKEN'
      exit 1
    fi
    LD_URL="https://app.launchdarkly.com/api/v2/flags/${product}/${launchDarklyFlagKey}"
    LD_HTTP_CODE=\$(curl -s -o ld_patch_response.json -w '%{http_code}' -X PATCH \\
      -H "Authorization: \$LD_API_TOKEN" \\
      -H "LD-API-Version: ${launchDarklyApiVersion}" \\
      -H "Content-Type: application/json" \\
      -d '${patchPayload}' \\
      "\$LD_URL")
    LD_CURL_EXIT=\$?
    echo "LaunchDarkly PATCH HTTP status: \$LD_HTTP_CODE"
    if [ -s ld_patch_response.json ]; then
      echo 'LaunchDarkly PATCH response body:'
      cat ld_patch_response.json
    fi
    if [ "\$LD_CURL_EXIT" -ne 0 ]; then
      echo 'LaunchDarkly PATCH request failed to execute.'
      exit 1
    fi
    if ! echo "\$LD_HTTP_CODE" | grep -Eq '^[0-9]{3}\$'; then
      echo 'LaunchDarkly PATCH returned an invalid status code.'
      exit 1
    fi
    if [ "\$LD_HTTP_CODE" -lt 200 ] || [ "\$LD_HTTP_CODE" -ge 300 ]; then
      echo 'LaunchDarkly PATCH failed with non-2xx status.'
      exit 1
    fi
  """
}

// Switch the staging app-mode flag to the legacy variation for UAT-Technical.
void setLaunchDarklyFlagToLegacy() {
  patchLaunchDarklyFlagState(
    true,
    launchDarklyLegacyVariationName,
    'Setting LaunchDarkly flag to legacy for staging...'
  )
}

// Restore the staging app-mode flag back to the standard Opal variation.
void restoreLaunchDarklyFlag() {
  patchLaunchDarklyFlagState(
    true,
    launchDarklyOpalVariationName,
    'Restoring LaunchDarkly flag to opal for staging...'
  )
}

// Probe the nightly staging health endpoint used before running UAT-Technical tests.
String getHealthCheckStatus() {
  String legacyHealthEndpoint = "${env.STG_OPAL_LEGACY_GATEWAY_URL}?actionType=getGmasTest"
  return sh(
    script: "curl -s -o /dev/null -w '%{http_code}' '${legacyHealthEndpoint}' || echo '000'",
    returnStdout: true
  ).trim()
}

// Wait until the staging health endpoint responds successfully after toggling app mode.
void waitForUatHealthCheck() {
  timeout(time: uatHealthCheckTimeoutMinutes, unit: 'MINUTES') {
    script {
      boolean healthy = false
      int maxAttempts = Math.max(
        1,
        (int) Math.ceil((uatHealthCheckTimeoutMinutes * 60.0d) / uatHealthCheckIntervalSeconds)
      )

      for (int attemptIndex = zeroIndex; attemptIndex < maxAttempts; attemptIndex++) {
        String statusCode = healthCheckStatus
        if (statusCode.startsWith('2')) {
          echo "Health check OK (HTTP ${statusCode})"
          healthy = true
          break
        }

        int attemptNumber = attemptIndex + 1
        echo "Health check returned ${statusCode}, waiting ${uatHealthCheckIntervalSeconds}s " +
          "(attempt ${attemptNumber}/${maxAttempts})..."
        sleep uatHealthCheckIntervalSeconds
      }

      if (!healthy) {
        error 'Health check did not succeed in time'
      }
    }
  }
}

// Archive updated parallel weight files for reuse by later nightly runs.
void archiveNightlyWeightArtifacts() {
  script {
    String sourceJobName = env.JOB_NAME
    String pipelineDir = 'cypress/parallel/weights/pipeline'
    String weightsDir = 'cypress/parallel/weights'
    String smokeWeights = 'smoke-parallel-weights.json'
    String functionalWeights = 'functional-parallel-weights.json'

    sh "mkdir -p ${pipelineDir}"
    sh "cp -r ${weightsDir}/${smokeWeights} ${pipelineDir}/"
    sh "cp -r ${weightsDir}/${functionalWeights} ${pipelineDir}/"

    sh "echo 'Archiving weight files in ${sourceJobName}'"
    archiveArtifact("${pipelineDir}/${smokeWeights}")
    archiveArtifact("${pipelineDir}/${functionalWeights}")
    archiveArtifact('cypress/reports/smokeXmlReport.html')
    archiveArtifact('cypress/reports/functionalXmlReport.html')
  }
}

// Copy generated UAT-Technical report artifacts into a dedicated directory for publishing.
void prepareUatTechnicalArtifacts(String browserToRun) {
  sh """
    UAT_DIR='functional-output/prod/${browserToRun}/uat-technical'
    UAT_CUCUMBER_DIR="\$UAT_DIR/cucumber"
    SOURCE_CUCUMBER_DIR='functional-output/prod/${browserToRun}/cucumber'
    SOURCE_JUNIT_PATH='functional-output/prod/${browserToRun}/${browserToRun}-test-result.xml'
    mkdir -p "\$UAT_CUCUMBER_DIR"

    if [ -f "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.html" ]; then
      cp "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.html" "\$UAT_CUCUMBER_DIR/uat-technical-report.html"
    fi
    if [ -f "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.ndjson" ]; then
      cp "\$SOURCE_CUCUMBER_DIR/${browserToRun}-report.ndjson" "\$UAT_CUCUMBER_DIR/uat-technical-report.ndjson"
    fi
    if [ -f "\$SOURCE_JUNIT_PATH" ]; then
      cp "\$SOURCE_JUNIT_PATH" "\$UAT_DIR/uat-technical-test-result.xml"
    fi
  """
}

// Run component tests and publish browser-specific reports and screenshots.
void runComponentStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  boolean shouldRunWithZephyr,
  String browserToRun
) {
  runNightlyStage(enabled, 'Component Tests', failureResultValue, 'Component tests failed') {
    try {
      builder.yarn(shouldRunWithZephyr ? 'zephyr:test:opalComponent' : 'test:opalComponent')
    } finally {
      archiveArtifact(functionalProdArtifactsPath)
      archiveArtifact("functional-output/screenshots/${browserToRun}/component/**")
      publishHtmlReport(
        "functional-output/component-html/${browserToRun}/",
        'component-report.html',
        "Component Test Report (${browserToRun})"
      )
    }
  }
}

// Run the UAT-Technical staging checks against legacy app mode and publish a dedicated report.
void runUatTechnicalStage(
  boolean enabled,
  String failureResultValue,
  String browserToRun
) {
  runNightlyStage(enabled, 'UAT-Technical', failureResultValue, 'UAT-Technical failed') {
    boolean launchDarklyFlagPatched = false

    try {
      echo "Running UAT-Technical scenarios with TAGS=${uatTechnicalTagFilter}"
      setLaunchDarklyFlagToLegacy()
      launchDarklyFlagPatched = true
      waitForUatHealthCheck()
      sh 'echo "Waiting 30s for system warmup..." ; sleep 30'

      withEnv([
        "TAGS=${uatTechnicalTagFilter}",
        "CYPRESS_TAGS=${uatTechnicalTagFilter}",
        'DEFAULT_APP_MODE=legacy',
        'LEGACY_ENABLED=true',
        "BROWSER_TO_RUN=${browserToRun}",
      ]) {
        sh 'node scripts/run-yarn-sequence.js test:functional:tags'
      }

      prepareUatTechnicalArtifacts(browserToRun)
    } finally {
      archiveArtifact(functionalProdArtifactsPath)
      archiveArtifact('functional-output/account_evidence/created-accounts.json')
      archiveArtifact('functional-output/account_evidence/**')
      archiveArtifact("functional-output/screenshots/${browserToRun}/**")
      archiveArtifact("functional-output/prod/${browserToRun}/uat-technical/**")
      publishHtmlReport(
        "functional-output/prod/${browserToRun}/uat-technical/cucumber/",
        'uat-technical-report.html',
        "UAT-Technical Functional Test Report (${browserToRun})"
      )
      if (launchDarklyFlagPatched) {
        restoreLaunchDarklyFlag()
      }
    }
  }
}

// Run smoke tests and publish browser-specific reports and screenshots.
void runSmokeStage(
  boolean enabled,
  String failureResultValue,
  uk.gov.hmcts.contino.YarnBuilder builder,
  String browserToRun
) {
  if (enabled && (env.SKIP_SMOKE ?: stringFalse).toBoolean()) {
    stage(smokeStageName) {
      echo "Skipping smoke tests because TAGS=${env.TAGS}"
    }
    return
  }

  runNightlyStage(enabled, smokeStageName, failureResultValue, 'Smoke tests failed') {
    try {
      builder.yarn('test:smoke')
    } finally {
      archiveArtifact('smoke-output/prod/**')
      archiveArtifact("smoke-output/screenshots/${browserToRun}/**")
      publishHtmlReport(
        "smoke-output/prod/${browserToRun}/cucumber/",
        'smoke-report.html',
        "${browserToRun.capitalize()} Smoke Test Report"
      )
    }
  }
}

