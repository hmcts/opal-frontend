{
  "extends": "./tsconfig.json",
  "compilerOptions": {
    "rootDir": "./cypress",
    "outDir": "./out-tsc/e2e",
    "types": ["cypress", "node", "@cypress/grep"],
    "typeRoots": ["./node_modules/@types", "./node_modules/@cypress"],
    "paths": {
      "@e2e/*": ["./cypress/e2e/*"],
      "cypress/e2e/*": ["./cypress/e2e/*"],
      "cypress/shared/*": ["./cypress/shared/*"],
      "cypress/support/*": ["./cypress/support/*"]
    }
  },
  "include": [
    "cypress/e2e/**/*.ts",
    "cypress/support/**/*.ts",
    "cypress/shared/**/*.ts"
  ],
  "exclude": ["node_modules", "cypress/component", "**/*.cy.ts"]
}
