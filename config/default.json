{
  "node-env": "development",
  "frontend-hostname": {
    "dev": "http://localhost:4200",
    "prod": "http://localhost:4000"
  },
  "opal-api": {
    "opal-fines-service": "http://localhost:4550",
    "opal-user-service": "http://localhost:4555"
  },
  "features": {
    "redis": {
      "enabled": true
    },
    "sso": {
      "enabled": false
    },
    "helmet": {
      "enabled": false
    },
    "launch-darkly": {
      "enabled": true,
      "stream": true
    },
    "feature-flags": {
      "override": false,
      "releases": {
        "release-1a": true,
        "release-1b": true,
        "release-1c-write-off": true,
        "release-1c-auto-enforcement": true,
        "release-1d-data-retention": true,
        "release-1d-auto-enforcement-config": true,
        "release-1c-rm-financial-movements": true,
        "release-1c-rm-financial-checks": true,
        "release-1c-rm-suspense": true,
        "release-1c-rm-payment": true,
        "release-1c-rm-admin-reports": true,
        "release-1c-rm-account-actions": true,
        "release-1c-financial-movements": true,
        "release-1c-checks": true,
        "release-1c-suspense": true,
        "release-1c-payment": true,
        "release-1c-r1a-tidy-up": true,
        "release-1c-reference-data": true,
        "release-1c-banking-interfaces": true,
        "release-1c-cpp-enforcement": true,
        "release-1c-cpp": true,
        "release-1c-printing": true,
        "release-1c-enforcement-operational-reporting": true
      }
    },
    "app-insights": {
      "enabled": false
    },
    "ip-logging": {
      "enabled": false
    }
  },
  "session": {
    "prefix": "opal-session",
    "ttlInSeconds": 1200,
    "maxAge": null,
    "secure": false,
    "sameSite": "lax",
    "domain": ""
  },
  "csrf": {
    "cookieName": "XSRF-TOKEN",
    "secure": false,
    "sameSite": "strict"
  },
  "secrets": {
    "opal": {
      "redis-connection-string": "redis://localhost:6379",
      "opal-frontend-session-secret": "supersecret",
      "opal-frontend-cookie-secret": "supersecret",
      "opal-frontend-csrf-secret": "supersecret",
      "app-insights-connection-string": "supersecret",
      "AzureADClientId": "failtst4",
      "AzureADClientSecret": "failtst4",
      "AzureADTenantId": "failtst4"
    }
  },
  "expiry": {
    "testMode": false,
    "default": {
      "expiryTimeInMilliseconds": 1800000,
      "warningThresholdInMilliseconds": 1800000
    },
    "test": {
      "expiryTimeInMilliseconds": 300000,
      "warningThresholdInMilliseconds": 300000
    },
    "userStateExpiryInMilliseconds": 60000
  },
  "application-insights": {
    "cloudRoleName": "opal-frontend"
  },
  "microsoft": {
    "url": "https://login.microsoftonline.com/"
  },
  "opal-user-service-urls": {
    "userStateUrl": "/v2/users/0/state",
    "addUserUrl": "/users",
    "updateUserUrl": "/users"
  },
  "user-state": {
    "cacheKeyPrefix": "USER_STATE_",
    "routePath": "/api/user-state",
    "tokenClaim": "sub",
    "domain": "fines"
  }
}
